package com.billing.billingsystem.util;

import java.io.File;
import java.time.LocalDateTime;

import com.billing.billingsystem.entity.Bill;
import com.itextpdf.kernel.pdf.PdfWriter;
import com.itextpdf.kernel.pdf.PdfDocument;
import com.itextpdf.layout.Document;
import com.itextpdf.layout.element.Paragraph;

public class PdfGenerator {

    public static void generateBillPdf(Bill bill) {

        try {

            String fileName = "bill_" + bill.getId() + ".pdf";

            String path = "C:/bills/" + fileName;

            File folder = new File("C:/bills");
            if(!folder.exists()){
                folder.mkdir();
            }

            PdfWriter writer = new PdfWriter(path);

            PdfDocument pdf = new PdfDocument(writer);

            Document document = new Document(pdf);

            document.add(new Paragraph("SUPERMARKET BILL"));
            document.add(new Paragraph("-------------------------"));

            document.add(new Paragraph("Customer: " + bill.getCustomerName()));

            document.add(new Paragraph("Date: " + LocalDateTime.now()));

            document.add(new Paragraph(""));

            document.add(new Paragraph("Total Amount: ₹" + bill.getTotalAmount()));

            document.add(new Paragraph("-------------------------"));

            document.add(new Paragraph("Thank You For Shopping!"));

            document.close();

            System.out.println("PDF Bill Created: " + path);

        } catch (Exception e) {

            e.printStackTrace();
        }
    }
}